PORT=3000
HOST=0.0.0.0
# Public URL or LAN IP shown in /health (use your deployed host when online)
PUBLIC_HOST=172.20.1.64

# Supabase (required) — https://supabase.com/dashboard
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_AVATAR_BUCKET=avatars

# Gmail OAuth (recommended with Authenticator / 2FA — extension "Connect with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gmail SMTP fallback (16-char App Password, not Authenticator code)
SMTP_GMAIL_USER=your@gmail.com
SMTP_GMAIL_PASS=your_app_password
SMTP_GMAIL_HOST=smtp.gmail.com
SMTP_GMAIL_PORT=587

# Outlook SMTP (required to send to @outlook.com / @hotmail.com recipients)
SMTP_OUTLOOK_USER=your@outlook.com
SMTP_OUTLOOK_PASS=your_app_password
SMTP_OUTLOOK_HOST=smtp-mail.outlook.com
SMTP_OUTLOOK_PORT=587
